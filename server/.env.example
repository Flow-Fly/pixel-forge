PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:5173
BUILD_REVISION=development

# Used only by explicit database commands and adapters. The web server still
# starts without database configuration.
DATABASE_URL=postgresql://pixel_forge:pixel_forge_local@127.0.0.1:5432/pixel_forge_dev
DATABASE_MAX_CONNECTIONS=4

# Required by commands that apply migrations. Set this deliberately in the
# command environment; it is not a production detector.
# DATABASE_SAFETY_CONFIRM=non-production

# Used only by explicit storage commands and adapters. The web server still
# starts without storage configuration.
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=pixel-forge-dev
STORAGE_ACCESS_KEY_ID=pixel_forge
STORAGE_SECRET_ACCESS_KEY=pixel_forge_local_secret
STORAGE_FORCE_PATH_STYLE=true

# Required by commands that mutate local storage. The command also requires a
# loopback endpoint; neither check is a production detector.
# STORAGE_SAFETY_CONFIRM=local-non-production
