{
  "name": "pixel-forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server"
  ],
  "scripts": {
    "dev": "npm run shared:build && vite",
    "build": "npm run shared:build && tsc && vite build",
    "preview": "vite preview",
    "pwa:preview": "npm run build && vite preview --host 127.0.0.1",
    "test": "npm run shared:build && vitest",
    "test:run": "npm run shared:build && vitest run && npm run shared:node-test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run shared:build",
    "fallow:audit": "fallow audit",
    "shared:build": "npm run build --workspace @pixel-forge/shared",
    "shared:node-test": "npm run test:node --workspace @pixel-forge/shared",
    "shared:test": "npm run test --workspace @pixel-forge/shared",
    "shared:typecheck": "npm run typecheck --workspace @pixel-forge/shared",
    "server:build": "npm run build --workspace @pixel-forge/server",
    "server:db:generate": "npm run db:generate --workspace @pixel-forge/server",
    "server:db:migrate": "npm run db:migrate --workspace @pixel-forge/server",
    "server:db:ready": "npm run db:ready --workspace @pixel-forge/server",
    "server:db:test": "npm run test:database --workspace @pixel-forge/server",
    "server:dev": "npm run dev --workspace @pixel-forge/server",
    "server:lint": "npm run lint --workspace @pixel-forge/server",
    "server:start": "npm run start --workspace @pixel-forge/server",
    "server:test": "npm run test --workspace @pixel-forge/server",
    "server:typecheck": "npm run typecheck --workspace @pixel-forge/server"
  },
  "dependencies": {
    "@pixel-forge/shared": "0.1.0",
    "@lit-labs/signals": "^0.1.3",
    "@sentry/browser": "^10.63.0",
    "idb": "^8.0.3",
    "lit": "^3.3.1",
    "pako": "^2.1.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pako": "^2.0.4",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.0.14",
    "eslint": "^10.6.0",
    "fake-indexeddb": "^6.2.5",
    "fallow": "^3.2.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0"
  }
}
